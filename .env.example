# Copy this file to .env and replace every CHANGE_ME value.

# Authentication and persistence
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
LITELLM_MASTER_KEY=sk-CHANGE_ME_LONG_RANDOM_MASTER_KEY
LITELLM_SALT_KEY=sk-CHANGE_ME_STABLE_SALT_KEY
VLLM_API_KEY=local-vllm
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_GRAFANA_PASSWORD

# Hugging Face token is only required for gated models.
HF_TOKEN=

# vLLM uses nightly because Qwen3.5 currently requires the main branch.
VLLM_IMAGE=vllm/vllm-openai:nightly

# Main profile: community AWQ-quantized multimodal Qwen3.5 for a 12 GB GPU.
MAIN_MODEL_ID=QuantTrio/Qwen3.5-4B-AWQ
MAIN_VLLM_MAX_MODEL_LEN=8192
MAIN_VLLM_GPU_MEMORY_UTILIZATION=0.85
MAIN_CPU_OFFLOAD_GB=0
MAIN_REASONING_PARSER=qwen3
MAIN_TOOL_CALL_PARSER=qwen3_coder
MAIN_MAX_IMAGES=2
MAIN_VLLM_PORT=8001

# Alternate profile: quantized text model served as qwen3-4b-awq.
ALT_MODEL_ID=Qwen/Qwen3-4B-AWQ
ALT_MAX_MODEL_LEN=16384
ALT_VLLM_GPU_MEMORY_UTILIZATION=0.85
ALT_REASONING_PARSER=qwen3
ALT_VLLM_PORT=8002

# Host ports
LITELLM_PORT=4000
OPEN_WEBUI_PORT=3000
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090
ALLOY_PORT=12345

# Data retention
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILES=3

# Pinned service versions. Update deliberately, not via floating latest/main tags.
POSTGRES_VERSION=17-alpine
LITELLM_VERSION=v1.90.5
OPEN_WEBUI_VERSION=v0.10.2
PROMETHEUS_VERSION=v3.4.1
LOKI_VERSION=3.5.1
TEMPO_VERSION=2.8.1
ALLOY_VERSION=v1.17.1
GRAFANA_VERSION=13.1.1
NVIDIA_EXPORTER_VERSION=1.3.2
